---
// Header Component
---

<header class="header">
  <div class="container">
    <a href="/" class="logo">Findcation</a>
    <a href="https://app.findcation.vn/auth/login" class="cta-button">Đăng nhập</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 1.5rem;
    transition: all 0.2s ease-in-out;
  }

  .container {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .cta-button {
    flex-shrink: 0;
    display: inline-block;
    padding: 0.875rem 1.25rem;
    background: linear-gradient(135deg, #ff4081 0%, #ff0f5e 100%);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 9999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 14px 0 rgba(255, 15, 94, 0.25);
    white-space: nowrap;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 15, 94, 0.4);
  }
</style>
