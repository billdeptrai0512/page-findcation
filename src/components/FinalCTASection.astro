---
// Final CTA Section
---

<section class="final-cta-section">
  <div class="container">
    <div class="cta-box">
      <h2 class="cta-headline">T&igrave;m staycation gần bạn ngay</h2>
      <p class="cta-subtext">Kh&aacute;m ph&aacute; ngay h&agrave;ng ng&agrave;n lựa chọn staycation với t&iacute;nh năng tự check-in tiện lợi.</p>
      
      <a href="https://app.findcation.vn" class="cta-button">
        Open Findcation
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    padding: 6rem 1.5rem;
    background-color: #ffffff;
  }

  .container {
    max-width: 1024px;
    margin: 0 auto;
  }

  .cta-box {
    background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    border-radius: 24px;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
  }

  /* Decorative background shapes */
  .cta-box::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(227, 28, 95, 0.4) 0%, transparent 70%);
    z-index: 0;
  }

  .cta-box::after {
    content: '';
    position: absolute;
    bottom: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(88, 138, 200, 0.4) 0%, transparent 70%);
    z-index: 0;
  }

  .cta-headline, .cta-subtext, .cta-button {
    position: relative;
    z-index: 10;
  }

  .cta-headline {
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .cta-subtext {
    font-size: 1.125rem;
    color: #9ca3af;
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1.125rem 2.5rem;
    background: linear-gradient(to right, #E61E4D 0%, #E31C5F 50%, #D70466 100%);
    color: white;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 9999px;
    box-shadow: 0 8px 20px rgba(230, 30, 77, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(230, 30, 77, 0.5);
  }

  @media (max-width: 640px) {
    .cta-headline {
      font-size: 2rem;
    }
    .cta-box {
      padding: 3rem 1.5rem;
    }
  }
</style>
