---
// VerificationSection.astro
---

<section id="verification-section" class="verification-section">
  <div class="container">
    <div class="header-content">
      <h2 class="section-title">Lời mời hợp tác</h2>
      <p class="section-subtitle">Đăng staycation của bạn lên bản đồ.</p>
    </div>

    <div class="cards-container">

      <div class="host-cta">        
        <div class="cta-features">
                  <div class="feature-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <p>Mở khóa điểm uy tín.</p>
          </div>
          <div class="feature-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <p>Khách nhắn tin trực tiếp cho bạn.</p>
          </div>
          <div class="feature-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <p>Findcation không thu phí đặt phòng.</p>
          </div>
          <div class="feature-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <p>Bạn nhận 100% doanh thu.</p>
          </div>
        </div>

      </div>

      <!-- Trust Score Card -->
      <div class="trust-score-card">
        <div class="card-header">
          <span class="trust-title">Điểm uy tín</span>
          <div id="trust-score-badge" class="score-badge badge-none">Chưa đánh giá</div>
        </div>
        
        <div class="score-display">
          <span class="score-number" id="trust-score-value">0</span>
          <span class="score-total">/ 100</span>
        </div>

        <ul class="verification-checklist">
          {
            [
              { text: "Xác thực thông tin liên hệ", points: 10 },
              { text: "Xác thực địa chỉ", points: 20 },
              { text: "Sử dụng ảnh thật", points: 10 },
              { text: "Hoạt động trên 1 tháng", points: 10 },
              { text: "Hoạt động trên 3 tháng", points: 15 },
              { text: "Hoạt động trên 6 tháng", points: 15 },
              { text: "Hoạt động trên 12 tháng", points: 20 }
            ].map((item, index) => (
              <li class="check-item-container" style={`--item-index: ${index};`}>
                <label class="check-item-label">
                  <input type="checkbox" class="trust-checkbox" data-points={item.points} />
                  <div class="checkbox-custom">
                    <svg class="check-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                  <span class="check-text">{item.text}</span>
                </label>
              </li>
            ))
          }
        </ul>

        <div class="cta-action-row">
          <div class="pricing-info">
            <span class="pricing-label">Phí Duy Trì</span>
            <span class="pricing-amount">512.000đ<span class="pricing-period"> / tháng</span></span>
            <span class="pricing-cancel">Tự động gia hạn trước 5 ngày</span>
          </div>
          <a href="https://app.findcation.vn/auth/login" class="cta-button">Tham gia</a>
        </div>
      </div>

      <!-- Host CTA -->
     
      
    </div>
  </div>
</section>

<style>
  .verification-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.25rem;
    background-color: #ffffff;
    position: relative;
    overflow: hidden;
  }

  .container {
    width: 100%;
    max-width: 580px;
    margin: 0 auto;
  }

  .header-content {
    text-align: center;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: #4b5563;
    line-height: 1.6;
  }

  .cards-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Trust Score Card */
  .trust-score-card {
    background: #ffffff;
    border-radius: 24px;
    padding: 2.25rem;
    box-shadow: 0 12px 32px -4px rgba(0, 0, 0, 0.08), 0 4px 12px -2px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(229, 231, 235, 0.8);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .trust-score-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -8px rgba(0, 0, 0, 0.12), 0 8px 16px -4px rgba(0, 0, 0, 0.04);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .trust-title {
    font-weight: 600;
    color: #4b5563;
    font-size: 1.125rem;
  }

  .score-badge {
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    transition: all 0.3s ease;
  }

  .badge-none {
    background-color: #f3f4f6;
    color: #4b5563;
  }

  .badge-basic {
    background-color: #dbeafe;
    color: #2563eb;
  }

  .badge-good {
    background-color: #ecfdf5;
    color: #059669;
  }

  .badge-excellent {
    background-color: #fef3c7;
    color: #d97706;
  }

  .score-display {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .score-number {
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: #4b5563;
    font-variant-numeric: tabular-nums;
    transition: color 0.3s ease;
  }

  .score-number.score-none  { color: #4b5563; }
  .score-number.score-basic { color: #2563eb; }
  .score-number.score-good  { color: #059669; }
  .score-number.score-excellent { color: #d97706; }

  .score-total {
    font-size: 1.5rem;
    font-weight: 600;
    color: #9ca3af;
  }

  /* Checklist Styles */
  .verification-checklist {
    list-style: none;
    padding: 1.75rem 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    border-top: 1px solid #f3f4f6;
  }

  .check-item-container {
    opacity: 0;
    transform: translateX(-20px);
  }

  .check-item-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    user-select: none;
    padding: 0.25rem 0;
  }

  .trust-checkbox {
    display: none;
  }

  .checkbox-custom {
    width: 24px;
    height: 24px;
    border: 2px solid #d1d5db;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
    background: #ffffff;
  }

  .check-svg {
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.2s ease;
    color: white;
  }

  .trust-checkbox:checked + .checkbox-custom {
    background: #10b981;
    border-color: #10b981;
  }

  .trust-checkbox:checked + .checkbox-custom .check-svg {
    opacity: 1;
    transform: scale(1);
  }

  .check-item-label:hover .checkbox-custom {
    border-color: #10b981;
  }

  .check-text {
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .points-bonus {
    color: #10b981;
    font-size: 0.875rem;
    font-weight: 700;
    background: #ecfdf5;
    padding: 2px 8px;
    border-radius: 12px;
  }

  /* Underline emphasis utility */
  .text-underline {
    color: #111827;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  /* Host CTA */
  .host-cta {
    background: #ffffff;
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.2), 0 8px 10px -6px rgba(0,0,0,0.1);
    border: 1px solid rgba(229, 231, 235, 0.8);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .cta-title {
    font-size: 1.625rem;
    font-weight: 800;
    color: #111827;
    margin-bottom: 1.75rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .cta-features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .feature-row {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .feature-icon {
    color: #db2777;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .feature-row p {
    font-size: 1rem;
    color: #4b5563;
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
  }

  /* Pricing + CTA Action Row */
  .cta-action-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f3f4f6;
    flex-wrap: wrap;
  }

  .pricing-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .pricing-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-amount {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pricing-period {
    font-size: 1rem;
    font-weight: 500;
    color: #9ca3af;
  }

  .pricing-cancel {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.125rem;
  }

  .cta-button {
    flex-shrink: 0;
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: linear-gradient(135deg, #ff4081 0%, #ff0f5e 100%);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 9999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 14px 0 rgba(255, 15, 94, 0.25);
    white-space: nowrap;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 15, 94, 0.4);
  }

  /* Animations triggered by intersection observer */
  .is-visible .check-item-container {
    animation: fadeSlideRight 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--item-index) * 0.15s);
  }

  /* Keyframes */
  @keyframes fadeSlideRight {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes stroke {
    100% {
      stroke-dashoffset: 0;
    }
  }
</style>

<script>
  function setupVerificationCheckboxes() {
    const section = document.getElementById('verification-section');
    const scoreElement = document.getElementById('trust-score-value');
    const badgeElement = document.getElementById('trust-score-badge');
    const checkboxes = document.querySelectorAll('.trust-checkbox');
    if (!section || !scoreElement || !badgeElement || checkboxes.length === 0) return;

    let currentScore = 0;
    let targetScore = 0;
    let animationFrameId = null;

    const getBadgeInfo = (score) => {
      if (score < 50) return { text: "Thấp", className: "badge-none" };
      if (score < 75) return { text: "Cơ bản", className: "badge-basic" };
      if (score < 90) return { text: "Cao", className: "badge-good" };
      return { text: "Cao cấp", className: "badge-excellent" };
    };

    const updateBadge = (score) => {
      const info = getBadgeInfo(score);
      badgeElement.textContent = info.text;
      badgeElement.className = `score-badge ${info.className}`;
      // Sync score-number color with badge color
      const colorClass = info.className.replace('badge-', 'score-');
      scoreElement.className = `score-number ${colorClass}`;
    };

    // Reset ALL checkboxes on load so score is truly 0
    checkboxes.forEach(cb => { cb.checked = false; });
    scoreElement.textContent = "0";
    updateBadge(0);

    const animateScore = () => {
      if (currentScore === targetScore) return;
      
      const diff = Math.abs(targetScore - currentScore);
      const increment = diff > 5 ? Math.ceil(diff / 5) : 1;
      
      if (targetScore > currentScore) {
        currentScore = Math.min(targetScore, currentScore + increment);
      } else {
        currentScore = Math.max(targetScore, currentScore - increment);
      }
      
      scoreElement.textContent = currentScore.toString();
      updateBadge(currentScore);
      
      if (currentScore !== targetScore) {
        animationFrameId = requestAnimationFrame(animateScore);
      }
    };

    const updateScore = () => {
      targetScore = Array.from(checkboxes)
        .filter(cb => cb.checked)
        .reduce((sum, cb) => sum + parseInt(cb.dataset.points || '0', 10), 0);
      
      if (animationFrameId) cancelAnimationFrame(animationFrameId);
      animationFrameId = requestAnimationFrame(animateScore);
    };

    checkboxes.forEach(cb => {
      cb.addEventListener('change', updateScore);
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.25 });

    observer.observe(section);
  }

  // Handle standard DOM load and Astro's ViewTransitions if used
  document.addEventListener('astro:page-load', setupVerificationCheckboxes);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupVerificationCheckboxes);
  } else {
    setupVerificationCheckboxes();
  }
</script>
