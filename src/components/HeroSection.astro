---
import { tokens } from '../design-system/design-tokens';
import { colors } from '../design-system/colors';
import { typography } from '../design-system/typography';
import { spacing } from '../design-system/spacing';
import HeroMap from './HeroMap.jsx';
---

<section class="hero-section">
  <div class="content-container">
    <div class="header-text">
      <h1 class="headline">Tìm staycation</h1>
    </div>

    <div class="usp-badges">
      <span class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Check-in tự động
      </span>
      <span class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
        Gần bạn
      </span>
      <span class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Đúng địa chỉ
      </span>
      <span class="badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Đang hoạt động
      </span>
    </div>

    <div class="visual-container">
      <HeroMap client:only="react" />
    </div>

    <div class="cta-container">
      <p class="helper-text">Findcation cần vị trí của bạn để hoạt động.</p>
      <a href="https://app.findcation.vn" class="cta-button">Mở bản đồ</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 2rem 1.5rem 6rem;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
    box-sizing: border-box;
  }

  .content-container {
    max-width: 680px;
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .header-text {
    margin-bottom: 1rem;
  }

  .headline {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #111827;
    margin-bottom: 1rem;
  }

  .subtext {
    font-size: 1.125rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .usp-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    background-color: #f3f4f6;
    color: #374151;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .badge svg {
    color: #E31C5F; /* Primary gradient mid-color for pop */
  }

  .visual-container {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 280px;
    height: 0; /* flex: 1 drives actual height; needed for absolute child */
    margin-bottom: 2rem;
    border-radius: 20px;
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.1);
    background-color: #f0f7ff;
    overflow: hidden;
  }

  .map-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  /* Leaflet custom styles */
  :global(.leaflet-popup-content-wrapper) {
    border-radius: 12px;
    box-shadow: 0 8px 24px -6px rgba(0,0,0,0.15);
    padding: 0;
    overflow: hidden;
  }
  
  :global(.leaflet-popup-content) {
    margin: 0!important;
    font-family: inherit;
    line-height: normal;
  }
  
  :global(.leaflet-container) {
    font-family: inherit;
    z-index: 1;
  }

  /* User Popup */
  :global(.user-popup-content) {
    font-weight: 600;
    font-size: 14px;
    display: inline-block;
    padding: 12px;
    text-align: none
  }

  /* React specific overrides */
  :global(.clear-leaflet-icon) {
    background: transparent;
    border: none;
  }

  :global(.panel>div:nth-child(1)) {
    padding: 0px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.6);
  }

  :global(.panel>div:nth-child(1)>div) {
    margin: 0px !important;
  }

  .cta-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 320px;
    padding: 1rem 2rem;
    background: linear-gradient(to right, #E61E4D 0%, #E31C5F 50%, #D70466 100%);
    color: white;
    font-weight: 600;
    font-size: 1.125rem;
    border-radius: 9999px;
    box-shadow: 0 4px 14px rgba(230, 30, 77, 0.3);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(230, 30, 77, 0.4);
  }

  .helper-text {
    font-size: 0.875rem;
    color: #6b7280;
    text-align: center;
    max-width: 280px;
    white-space: nowrap;
  }

  .more-text {
    font-size: 0.875rem;
    color: #6b7280;
    text-align: center;
    max-width: 280px;
    white-space: nowrap;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 768px) {
    .headline {
      font-size: 3.5rem;
    }
    .subtext {
      font-size: 1.25rem;
    }
    .visual-container {
      min-height: 360px;
    }
  }
</style>
